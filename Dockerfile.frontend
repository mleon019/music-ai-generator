FROM node:22-bookworm-slim

WORKDIR /app/frontend

COPY frontend/package.json ./

RUN npm install

COPY frontend ./

ARG VITE_API_BASE_URL=http://localhost:3000
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL

RUN npm run build

EXPOSE 4173

CMD ["npm", "run", "preview", "--", "--host", "0.0.0.0", "--port", "4173"]

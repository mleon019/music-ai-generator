FROM node:22-bookworm-slim

WORKDIR /app

RUN apt-get update \
	&& apt-get install -y --no-install-recommends python3 make g++ \
	&& rm -rf /var/lib/apt/lists/*

COPY backend/package.json backend/package-lock.json ./backend/

WORKDIR /app/backend

RUN npm ci

COPY backend ./
COPY schema /app/schema

EXPOSE 3000

CMD ["node", "server.js"]
